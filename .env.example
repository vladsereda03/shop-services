# Copy to .env (or export in your shell) before `docker compose up`.
# Values already exported in the shell take precedence over .env.

# PostgreSQL superuser for the shop-postgres container (any values work)
POSTGRES_USER=shop
POSTGRES_PASSWORD=shop

# RSA key pair the auth server signs JWTs with: single-line Base64 over DER
# (public key: X.509/SPKI, private key: PKCS#8). Generate with openssl:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -outform DER | base64 -w0   -> JWT_PRIVATE_KEY
#   base64 -d <<< "$JWT_PRIVATE_KEY" | openssl pkey -inform DER -pubout -outform DER | base64 -w0 -> JWT_PUBLIC_KEY
JWK_KEY_ID=dev-key
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

# LiqPay merchant keys; the sandbox defaults below are fine for local demo
# (keep them in sync with scripts/emulate-liqpay-callback.ps1)
LIQPAY_PUBLIC_KEY=sandbox_public_key
LIQPAY_PRIVATE_KEY=sandbox_private_key

# OAuth2 client secrets. The dev defaults below match the values baked into the
# configs, so local runs and tests work unchanged; set real values in production.
# Each variable is read by BOTH sides: auth's registered client and that service's
# own client registration.
CLIENT_OAUTH_SECRET=secret
CART_SERVICE_SECRET=cart-service-secret
ORDER_SERVICE_SECRET=order-service-secret
PAYMENT_SERVICE_SECRET=payment-service-secret